{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm run dev:electron",
    "dev:electron": "concurrently -k -n vite,tsc,preload,electron -c blue,yellow,green,magenta \"vite --mode electron\" \"tsc -p tsconfig.electron.json --watch\" \"npm run dev:electron-preload\" \"wait-on tcp:5173 dist-electron/electron/main.js dist-electron/electron/preload.cjs && electron dist-electron/electron/main.js\"",
    "dev:electron-preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/electron/preload.cjs --external:electron --watch",
    "electron:watch": "concurrently -k -n tsc,preload,electron -c yellow,green,magenta \"tsc -p tsconfig.electron.json --watch\" \"npm run dev:electron-preload\" \"wait-on tcp:5173 dist-electron/electron/main.js dist-electron/electron/preload.cjs && electron dist-electron/electron/main.js\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && npm run build:electron-preload",
    "build:electron-preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/electron/preload.cjs --external:electron",
    "build:desktop": "npm run build && npm run build:electron",
    "start:electron": "electron dist-electron/electron/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.0"
  }
}
